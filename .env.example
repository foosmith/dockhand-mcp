# Dockhand MCP — environment variables
# Copy this file to .env and fill in your values

# Full URL to your Dockhand instance (no trailing slash)
DOCKHAND_URL=http://your-dockhand-host:port

# Credentials for the Dockhand user the MCP server will log in as.
# Recommendation: create a dedicated "claude" user in Dockhand rather
# than using your admin account (Settings > Authentication > Add User).
DOCKHAND_USERNAME=claude
DOCKHAND_PASSWORD=your_password_here
